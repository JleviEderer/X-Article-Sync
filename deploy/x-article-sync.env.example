# Required: absolute path to the Obsidian vault root on the server.
X_ARTICLE_SYNC_VAULT_ROOT=/srv/obsidian-vault

# Optional: folder inside the vault where article notes should be written.
X_ARTICLE_SYNC_OUTPUT_FOLDER=Outputs/X_Articles

# Optional: keep state outside the vault so reruns and backfills are stable.
X_ARTICLE_SYNC_STATE_PATH=/var/lib/x-article-sync/x-article-bookmarks.json

# Optional: keep remote image links and avoid local asset folders in the vault.
X_ARTICLE_SYNC_ASSETS_MODE=remote

# Optional: set to 0 if you want write-only behavior and do not want the launcher to commit/push vault changes.
X_ARTICLE_SYNC_PUSH_VAULT_CHANGES=1

# Optional: only needed if cron will not already export TWITTER_AUTH_TOKEN and CT0.
X_ARTICLE_SYNC_TWITTER_ENV_FILE=/home/ubuntu/.config/env/twitter.env

# Optional: set these if you want a specific commit author label for scoped vault commits.
# X_ARTICLE_SYNC_GIT_AUTHOR_NAME=X Article Sync
# X_ARTICLE_SYNC_GIT_AUTHOR_EMAIL=bot@example.com
